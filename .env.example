# Deployment mode: "self-hosted" or "hosted"
DEPLOYMENT_MODE=self-hosted

# Anthropic API Key (required for self-hosted, optional for hosted)
ANTHROPIC_API_KEY=

# Supabase (required for hosted mode, optional for self-hosted)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (hosted mode only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags
FEATURE_PAYMENT=false
FEATURE_PWA=true
